{
    "compilerOptions": {
        "declaration": true,
        "composite": true,
        "incremental": true,
        "noResolve": false,
        "module": "ES2015",
        "moduleResolution": "bundler",
        "noImplicitAny": true,
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "noUnusedLocals": true,
        "skipLibCheck": true,
        "strictNullChecks": true,
        "strictPropertyInitialization": true,
        "forceConsistentCasingInFileNames": true,
        "lib": ["DOM", "ESNext"],
        "esModuleInterop": true,
        "paths": {
            "tabster": ["./src/"],
            "tabster/lite": ["./src/lite/index.ts"],
            "tabster/lite/*": ["./src/lite/*"]
        }
    },
    "exclude": ["dist", "node_modules"]
}
