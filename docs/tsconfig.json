{
    // This file is not used in compilation. It is here just for a nice editor experience.
    "compilerOptions": {
        "allowJs": true,
        "esModuleInterop": true,
        "jsx": "react",
        "lib": ["dom"],
        "module": "esnext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "types": [
            "node",
            "@docusaurus/module-type-aliases",
            "@docusaurus/theme-classic"
        ],
        "paths": {
            "@site/*": ["./*"]
        },
        "skipLibCheck": true
    }
}
